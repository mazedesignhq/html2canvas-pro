{
  "name": "@mazeapp/html2canvas-pro",
  "publishConfig": {
    "access": "restricted"
  },
  "description": "Screenshots with JavaScript. Next generation!",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "version": "2.0.0",
  "author": {
    "name": "yorickshan",
    "email": "yorickshan@gmail.com",
    "url": "https://github.com/yorickshan"
  },
  "license": "MIT",
  "keywords": ["html2canvas", "screenshot"],
  "engines": {
    "node": ">=22.0.0"
  },
  "homepage": "https://yorickshan.github.io/html2canvas-pro/",
  "repository": {
    "type": "git",
    "url": "https://github.com/mazedesignhq/html2canvas-pro"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^24.6.1",
    "tsdown": "^0.15.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsdown --format esm --format cjs",
    "release": "sh scripts/version-upgrade.sh",
    "format": "biome check --write",
    "lint": "biome check",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "css-line-break": "^2.1.0",
    "text-segmentation": "^1.0.3"
  }
}
